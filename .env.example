# Telegram bot token from BotFather.
TELEGRAM_BOT_TOKEN=123456789:replace_me

# Optional but recommended: only ingest messages from this household chat.
TELEGRAM_CHAT_ID=123456789

# Base directory for local queue/state/database files.
# Defaults to the current working directory if unset.
BOT_BASE_DIR=/home/pi/stevens

# SQLite database location.
# Defaults to BOT_BASE_DIR/data/stevens.db if unset.
# STEVENS_DB_PATH=/home/pi/stevens/data/stevens.db

# Pi-to-Pico serial display target.
STEVENS_DISPLAY_DEVICE=/dev/ttyACM0

# Set to 1 to write display frames to data/last_display_frame.txt instead of serial.
STEVENS_DISPLAY_DRY_RUN=0

# Weather importer configuration.
STEVENS_WEATHER_LATITUDE=38.6270
STEVENS_WEATHER_LONGITUDE=-90.1994
STEVENS_TIMEZONE=America/Chicago

# Local Ollama settings for later LLM reintroduction.
OLLAMA_URL=http://127.0.0.1:11434/api/generate
OLLAMA_MODEL=smollm2:135m-instruct-Q4_K_S
